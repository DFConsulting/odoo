<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hotel_room_list" model="ir.ui.view">
        <field name="name">hotel.room.list</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <list string="Rooms">
                <field name="name"/>
                <field name="room_type_id"/>
                <field name="floor"/>
                <field name="status"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_hotel_room_form" model="ir.ui.view">
        <field name="name">hotel.room.form</field>
        <field name="model">hotel.room</field>
        <field name="arch" type="xml">
            <form string="Room">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Room Number"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="room_type_id"/>
                            <field name="floor"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hotel_room" model="ir.actions.act_window">
        <field name="name">Rooms</field>
        <field name="res_model">hotel.room</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo> 