<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hotel_room_tree" model="ir.ui.view">
        <field name="name">hotel.room.tree</field>
        <field name="model">hotel.room</field>
        <field name="type">list</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="room_type_id"/>
                <field name="floor"/>
                <field name="status"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_hotel_room_form" model="ir.ui.view">
        <field name="name">hotel.room.form</field>
        <field name="model">hotel.room</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Room Number"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="room_type_id"/>
                            <field name="floor"/>
                        </group>
                        <group>
                            <field name="status"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hotel_room" model="ir.actions.act_window">
        <field name="name">Rooms</field>
        <field name="res_model">hotel.room</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo> 